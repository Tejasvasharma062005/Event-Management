PORT=5000
JWT_SECRET=event_secret_key_123

# PostgreSQL Connection String (required)
# Get this from your provider:
#   Neon:     https://console.neon.tech  → your project → Connection Details → Connection string
#   Supabase: https://app.supabase.com   → Project Settings → Database → URI
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# SMTP Server Configurations (optional)
# Uncomment and fill these to send real password-reset emails.
# Without SMTP, reset links are logged to the backend console.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password

# Optional: Gemini API key for AI-enhanced event planning narratives
# GEMINI_API_KEY=your_gemini_api_key

# Optional: Stripe secret key for real payment processing
# STRIPE_SECRET_KEY=sk_test_...
